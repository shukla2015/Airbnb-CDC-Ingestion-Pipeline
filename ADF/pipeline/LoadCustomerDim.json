{
	"name": "LoadCustomerDim",
	"properties": {
		"description": "This pipeline will fetch the metadata of ADLS customer raw data then iterate on individual files, perform copy activity into synapse customer dim table.",
		"activities": [
			{
				"name": "GetMetadataCustomerData",
				"description": "Get Metadata from ADLS customer raw data folder.",
				"type": "GetMetadata",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"dataset": {
						"referenceName": "CustomerDataRaw",
						"type": "DatasetReference"
					},
					"fieldList": [
						"childItems"
					],
					"storeSettings": {
						"type": "AzureBlobFSReadSettings",
						"recursive": true,
						"enablePartitionDiscovery": false
					},
					"formatSettings": {
						"type": "DelimitedTextReadSettings"
					}
				}
			},
			{
				"name": "ForEachCustomerData",
				"description": "Iterating on files, which we get from get metadata activity.",
				"type": "ForEach",
				"dependsOn": [
					{
						"activity": "GetMetadataCustomerData",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@activity('GetMetadataCustomerData').output.childItems",
						"type": "Expression"
					},
					"activities": [
						{
							"name": "CheckCsvFile",
							"description": "It will return if the item is csv file",
							"type": "IfCondition",
							"dependsOn": [],
							"userProperties": [],
							"typeProperties": {
								"expression": {
									"value": "@endswith(item().name, '.csv')",
									"type": "Expression"
								},
								"ifTrueActivities": [
									{
										"name": "CopyIntoSynapseCustomer",
										"description": "Copy Customer CSV file data in ADLS into Customer Synapse table.",
										"type": "Copy",
										"dependsOn": [],
										"policy": {
											"timeout": "0.12:00:00",
											"retry": 0,
											"retryIntervalInSeconds": 30,
											"secureOutput": false,
											"secureInput": false
										},
										"userProperties": [
											{
												"name": "File_location",
												"value": "airbnb_customer_data_raw_folder"
											},
											{
												"name": "load_type",
												"value": "one_by_one"
											},
											{
												"name": "Sink_detail",
												"value": "customer_dim_table_Synapse"
											}
										],
										"typeProperties": {
											"source": {
												"type": "DelimitedTextSource",
												"storeSettings": {
													"type": "AzureBlobFSReadSettings",
													"recursive": false,
													"wildcardFolderPath": "customer_raw_data",
													"wildcardFileName": {
														"value": "@item().name\n",
														"type": "Expression"
													},
													"enablePartitionDiscovery": false
												},
												"formatSettings": {
													"type": "DelimitedTextReadSettings"
												}
											},
											"sink": {
												"type": "SqlDWSink",
												"writeBehavior": "Upsert",
												"upsertSettings": {
													"keys": [
														"customer_id"
													],
													"interimSchemaName": ""
												},
												"sqlWriterUseTableLock": false
											},
											"enableStaging": false,
											"translator": {
												"type": "TabularTranslator",
												"typeConversion": true,
												"typeConversionSettings": {
													"allowDataTruncation": true,
													"treatBooleanAsNumber": false
												}
											}
										},
										"inputs": [
											{
												"referenceName": "CustomerDataRaw",
												"type": "DatasetReference"
											}
										],
										"outputs": [
											{
												"referenceName": "BookingFactSynapse",
												"type": "DatasetReference"
											}
										]
									},
									{
										"name": "TempVariable",
										"description": "Count the files.",
										"type": "SetVariable",
										"dependsOn": [
											{
												"activity": "CopyCustomerData",
												"dependencyConditions": [
													"Succeeded"
												]
											}
										],
										"policy": {
											"secureOutput": false,
											"secureInput": false
										},
										"userProperties": [],
										"typeProperties": {
											"variableName": "temp_file",
											"value": {
												"value": "@add(variables('Total_file'), 1)",
												"type": "Expression"
											}
										}
									},
									{
										"name": "Final_value_updation",
										"description": "Assign the temp value in the final variable.",
										"type": "SetVariable",
										"dependsOn": [
											{
												"activity": "TempVariable",
												"dependencyConditions": [
													"Succeeded"
												]
											}
										],
										"policy": {
											"secureOutput": false,
											"secureInput": false
										},
										"userProperties": [],
										"typeProperties": {
											"variableName": "Total_file",
											"value": {
												"value": "@variables('temp_file')",
												"type": "Expression"
											}
										}
									},
									{
										"name": "CopyCustomerData",
										"description": "This activity copy all files from customer raw data folder into customer archive folder.",
										"type": "Copy",
										"dependsOn": [
											{
												"activity": "CopyIntoSynapseCustomer",
												"dependencyConditions": [
													"Succeeded"
												]
											}
										],
										"policy": {
											"timeout": "0.12:00:00",
											"retry": 0,
											"retryIntervalInSeconds": 30,
											"secureOutput": false,
											"secureInput": false
										},
										"userProperties": [],
										"typeProperties": {
											"source": {
												"type": "DelimitedTextSource",
												"storeSettings": {
													"type": "AzureBlobFSReadSettings",
													"recursive": true,
													"wildcardFolderPath": "customer_raw_data",
													"wildcardFileName": {
														"value": "@item().name",
														"type": "Expression"
													},
													"enablePartitionDiscovery": false
												},
												"formatSettings": {
													"type": "DelimitedTextReadSettings"
												}
											},
											"sink": {
												"type": "DelimitedTextSink",
												"storeSettings": {
													"type": "AzureBlobFSWriteSettings",
													"copyBehavior": "FlattenHierarchy"
												},
												"formatSettings": {
													"type": "DelimitedTextWriteSettings",
													"quoteAllText": true,
													"fileExtension": ".csv"
												}
											},
											"enableStaging": false,
											"parallelCopies": 1,
											"dataIntegrationUnits": 4,
											"translator": {
												"type": "TabularTranslator",
												"typeConversion": true,
												"typeConversionSettings": {
													"allowDataTruncation": true,
													"treatBooleanAsNumber": false
												}
											}
										},
										"inputs": [
											{
												"referenceName": "CustomerDataRaw",
												"type": "DatasetReference"
											}
										],
										"outputs": [
											{
												"referenceName": "CustomerArchive",
												"type": "DatasetReference"
											}
										]
									},
									{
										"name": "DeleteActivity",
										"description": "Delete files from customer raw data folder, after copying the data.",
										"type": "Delete",
										"dependsOn": [
											{
												"activity": "Final_value_updation",
												"dependencyConditions": [
													"Succeeded"
												]
											}
										],
										"policy": {
											"timeout": "0.12:00:00",
											"retry": 0,
											"retryIntervalInSeconds": 30,
											"secureOutput": false,
											"secureInput": false
										},
										"userProperties": [],
										"typeProperties": {
											"dataset": {
												"referenceName": "CustomerDataRaw",
												"type": "DatasetReference"
											},
											"enableLogging": true,
											"storeSettings": {
												"type": "AzureBlobFSReadSettings",
												"recursive": false,
												"wildcardFileName": {
													"value": "@{item().name}",
													"type": "Expression"
												},
												"enablePartitionDiscovery": false
											}
										}
									}
								]
							}
						}
					]
				}
			},
			{
				"name": "Total_files",
				"description": "Total files which performed upsert into azure synapse table.",
				"type": "SetVariable",
				"dependsOn": [
					{
						"activity": "ForEachCustomerData",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "Total_count_files",
					"value": {
						"value": "@variables('Total_file')",
						"type": "Expression"
					}
				}
			}
		],
		"variables": {
			"Total_file": {
				"type": "Integer",
				"defaultValue": 0
			},
			"temp_file": {
				"type": "Integer",
				"defaultValue": 0
			},
			"Total_count_files": {
				"type": "String"
			}
		},
		"annotations": []
	}
}