{
	"name": "dataflow1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "BookingStageData",
						"type": "DatasetReference"
					},
					"name": "sourceBookingStage"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "derivedColumns",
					"description": "Deriving the new columns to ingest in booking fact synapse table."
				}
			],
			"scriptLines": [
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet') ~> sourceBookingStage",
				"sourceBookingStage derive(full_address = concat(city, \" \",country),",
				"          column2 = ERROR_FUNCTION('')) ~> derivedColumns"
			]
		}
	}
}