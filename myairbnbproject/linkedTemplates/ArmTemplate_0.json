		{
			"name": "[concat(parameters('factoryName'), '/Last_Run_File')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "AzureDataLakeStorage1",
					"type": "LinkedServiceReference"
				},
				"annotations": [],
				"type": "Json",
				"typeProperties": {
					"location": {
						"type": "AzureBlobFSLocation",
						"fileName": "last_run_file.json",
						"folderPath": "last_run_data",
						"fileSystem": "airbnb-data"
					}
				},
				"schema": {
					"type": "object",
					"properties": {
						"lastRunTime": {
							"type": "string"
						}
					}
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/AzureDataLakeStorage1')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/LoadCustomerDim')]",
			"type": "Microsoft.DataFactory/factories/pipelines",
			"apiVersion": "2018-06-01",
			"properties": {
				"description": "This pipeline will fetch the metadata of ADLS customer raw data then iterate on individual files, perform copy activity into synapse customer dim table.",
				"activities": [
					{
						"name": "GetMetadataCustomerData",
						"description": "Get Metadata from ADLS customer raw data folder.",
						"type": "GetMetadata",
						"dependsOn": [],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"dataset": {
								"referenceName": "CustomerDataRaw",
								"type": "DatasetReference",
								"parameters": {}
							},
							"fieldList": [
								"childItems"
							],
							"storeSettings": {
								"type": "AzureBlobFSReadSettings",
								"recursive": true,
								"enablePartitionDiscovery": false
							},
							"formatSettings": {
								"type": "DelimitedTextReadSettings"
							}
						}
					},
					{
						"name": "ForEachCustomerData",
						"description": "Iterating on files, which we get from get metadata activity.",
						"type": "ForEach",
						"dependsOn": [
							{
								"activity": "GetMetadataCustomerData",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"userProperties": [],
						"typeProperties": {
							"items": {
								"value": "@activity('GetMetadataCustomerData').output.childItems",
								"type": "Expression"
							},
							"isSequential": true,
							"activities": [
								{
									"name": "CheckCsvFile",
									"description": "Condition True if the item is csv file, else False.",
									"type": "IfCondition",
									"dependsOn": [],
									"userProperties": [],
									"typeProperties": {
										"expression": {
											"value": "@endswith(item().name, '.csv')",
											"type": "Expression"
										},
										"ifTrueActivities": [
											{
												"name": "UpsertIntoSynapseCustomer",
												"description": "Insert or Update Customer CSV file data from ADLS into Customer Synapse table.",
												"type": "Copy",
												"dependsOn": [],
												"policy": {
													"timeout": "0.12:00:00",
													"retry": 0,
													"retryIntervalInSeconds": 30,
													"secureOutput": false,
													"secureInput": false
												},
												"userProperties": [
													{
														"name": "File_location",
														"value": "airbnb_customer_data_raw_folder"
													},
													{
														"name": "load_type",
														"value": "one_by_one"
													},
													{
														"name": "Sink_detail",
														"value": "customer_dim_table_Synapse"
													}
												],
												"typeProperties": {
													"source": {
														"type": "DelimitedTextSource",
														"storeSettings": {
															"type": "AzureBlobFSReadSettings",
															"recursive": false,
															"wildcardFolderPath": "customer_raw_data",
															"wildcardFileName": {
																"value": "@item().name\n",
																"type": "Expression"
															},
															"enablePartitionDiscovery": false
														},
														"formatSettings": {
															"type": "DelimitedTextReadSettings"
														}
													},
													"sink": {
														"type": "SqlDWSink",
														"writeBehavior": "Upsert",
														"upsertSettings": {
															"keys": [
																"customer_id"
															],
															"interimSchemaName": ""
														},
														"sqlWriterUseTableLock": false
													},
													"enableStaging": false,
													"translator": {
														"type": "TabularTranslator",
														"typeConversion": true,
														"typeConversionSettings": {
															"allowDataTruncation": true,
															"treatBooleanAsNumber": false
														}
													}
												},
												"inputs": [
													{
														"referenceName": "CustomerDataRaw",
														"type": "DatasetReference",
														"parameters": {}
													}
												],
												"outputs": [
													{
														"referenceName": "BookingFactSynapse",
														"type": "DatasetReference",
														"parameters": {}
													}
												]
											},
											{
												"name": "CopyToCustomerArchive",
												"description": "This activity copy all files from customer raw data folder into customer archive folder.",
												"type": "Copy",
												"dependsOn": [
													{
														"activity": "UpsertIntoSynapseCustomer",
														"dependencyConditions": [
															"Succeeded"
														]
													}
												],
												"policy": {
													"timeout": "0.12:00:00",
													"retry": 0,
													"retryIntervalInSeconds": 30,
													"secureOutput": false,
													"secureInput": false
												},
												"userProperties": [],
												"typeProperties": {
													"source": {
														"type": "DelimitedTextSource",
														"storeSettings": {
															"type": "AzureBlobFSReadSettings",
															"recursive": true,
															"wildcardFolderPath": "customer_raw_data",
															"wildcardFileName": {
																"value": "@item().name",
																"type": "Expression"
															},
															"enablePartitionDiscovery": false
														},
														"formatSettings": {
															"type": "DelimitedTextReadSettings"
														}
													},
													"sink": {
														"type": "DelimitedTextSink",
														"storeSettings": {
															"type": "AzureBlobFSWriteSettings",
															"copyBehavior": "FlattenHierarchy"
														},
														"formatSettings": {
															"type": "DelimitedTextWriteSettings",
															"quoteAllText": true,
															"fileExtension": ".csv"
														}
													},
													"enableStaging": false,
													"parallelCopies": 1,
													"dataIntegrationUnits": 4,
													"translator": {
														"type": "TabularTranslator",
														"typeConversion": true,
														"typeConversionSettings": {
															"allowDataTruncation": true,
															"treatBooleanAsNumber": false
														}
													}
												},
												"inputs": [
													{
														"referenceName": "CustomerDataRaw",
														"type": "DatasetReference",
														"parameters": {}
													}
												],
												"outputs": [
													{
														"referenceName": "CustomerArchive",
														"type": "DatasetReference",
														"parameters": {}
													}
												]
											},
											{
												"name": "DeleteActivity",
												"description": "Delete Csv files from customer raw data folder, after performing copy files into customer archive folder.",
												"type": "Delete",
												"dependsOn": [
													{
														"activity": "IndividualFile",
														"dependencyConditions": [
															"Succeeded"
														]
													}
												],
												"policy": {
													"timeout": "0.12:00:00",
													"retry": 0,
													"retryIntervalInSeconds": 30,
													"secureOutput": false,
													"secureInput": false
												},
												"userProperties": [],
												"typeProperties": {
													"dataset": {
														"referenceName": "CustomerDataRaw",
														"type": "DatasetReference",
														"parameters": {}
													},
													"logStorageSettings": {
														"linkedServiceName": {
															"referenceName": "AzureDataLakeStorage1",
															"type": "LinkedServiceReference"
														},
														"path": "airbnb-data/logging_file"
													},
													"enableLogging": true,
													"storeSettings": {
														"type": "AzureBlobFSReadSettings",
														"recursive": false,
														"wildcardFileName": {
															"value": "@item().name",
															"type": "Expression"
														},
														"enablePartitionDiscovery": false
													}
												}
											},
											{
												"name": "IndividualFile",
												"description": "This Activity tells which files are processed.",
												"type": "SetVariable",
												"dependsOn": [
													{
														"activity": "CopyToCustomerArchive",
														"dependencyConditions": [
															"Succeeded"
														]
													}
												],
												"policy": {
													"secureOutput": false,
													"secureInput": false
												},
												"userProperties": [],
												"typeProperties": {
													"variableName": "EachFile",
													"value": {
														"value": "@item().name",
														"type": "Expression"
													}
												}
											}
										]
									}
								}
							]
						}
					},
					{
						"name": "Total_files",
						"description": "Total files which performed upsert into azure synapse table.",
						"type": "SetVariable",
						"dependsOn": [
							{
								"activity": "ForEachCustomerData",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"policy": {
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"variableName": "Total_count_files",
							"value": {
								"value": "@variables('Total_file')",
								"type": "Expression"
							}
						}
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"variables": {
					"Total_file": {
						"type": "Integer",
						"defaultValue": 0
					},
					"temp_file": {
						"type": "Integer",
						"defaultValue": 0
					},
					"Total_count_files": {
						"type": "String"
					},
					"EachFile": {
						"type": "String"
					}
				},
				"annotations": []
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/CustomerDataRaw')]",
				"[concat(variables('factoryId'), '/datasets/BookingFactSynapse')]",
				"[concat(variables('factoryId'), '/datasets/CustomerArchive')]",
				"[concat(variables('factoryId'), '/linkedServices/AzureDataLakeStorage1')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/TransformDataToSynapse')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "BookingStageData",
								"type": "DatasetReference"
							},
							"name": "sourceBookingStage"
						},
						{
							"dataset": {
								"referenceName": "BookingFactSynapse",
								"type": "DatasetReference"
							},
							"name": "SynapseForLookup"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "BookingFactSynapse",
								"type": "DatasetReference"
							},
							"name": "SynapseFactWrite",
							"rejectedDataLinkedService": {
								"referenceName": "AzureDataLakeStorage1",
								"type": "LinkedServiceReference"
							}
						}
					],
					"transformations": [
						{
							"name": "derivedColumns",
							"description": "Deriving the new columns to ingest in booking fact synapse table."
						},
						{
							"name": "ModifyColumnsDataType",
							"description": "Convert data type of existing columns."
						},
						{
							"name": "AcceptedRecords",
							"description": "Conditionally distributed data based on columns check in date and check out date."
						},
						{
							"name": "AlterRow",
							"description": "Tell the target which records are updates and inserts."
						},
						{
							"name": "parseColumnInJson",
							"description": "parse column property location into struct type."
						},
						{
							"name": "selectColumns",
							"description": "Fetch columns to perform upsert in synapse"
						},
						{
							"name": "LookupInSynapse"
						},
						{
							"name": "FinalColumns",
							"description": "Preparing final columns to upsert into synapse table."
						}
					],
					"scriptLines": [
						"source(output(",
						"          {_id} as string,",
						"          booking_id as string,",
						"          property_id as string,",
						"          customer_id as long,",
						"          owner_id as string,",
						"          check_in_date as string,",
						"          check_out_date as string,",
						"          booking_date as string,",
						"          amount as double,",
						"          currency as string,",
						"          property_location as string,",
						"          timestamp as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false,",
						"     format: 'parquet') ~> sourceBookingStage",
						"source(output(",
						"          booking_id as string,",
						"          property_id as string,",
						"          customer_id as integer,",
						"          owner_id as string,",
						"          check_in_date as date,",
						"          check_out_date as date,",
						"          booking_date as timestamp,",
						"          amount as double,",
						"          currency as string,",
						"          city as string,",
						"          country as string,",
						"          full_address as string,",
						"          stay_duration as long,",
						"          booking_year as integer,",
						"          booking_month as integer,",
						"          timestamp as timestamp",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     isolationLevel: 'READ_UNCOMMITTED',",
						"     format: 'table',",
						"     staged: true) ~> SynapseForLookup",
						"AcceptedRecords@AcceptedRecords derive(full_address = concatWS(\" \", parse_property_location.city, parse_property_location.country),",
						"          stay_duration = (toTimestamp(check_out_date) - toTimestamp(check_in_date)) / 86400000000,",
						"          booking_year = year(booking_date),",
						"          booking_month = month(booking_date),",
						"          city = parse_property_location.city,",
						"          country = parse_property_location.country) ~> derivedColumns",
						"parseColumnInJson derive(check_in_date = toDate(check_in_date, \"yyyy-MM-dd HH:MM:SS\"),",
						"          check_out_date = toDate(check_out_date, \"yyyy-MM-dd HH:MM:SS\"),",
						"          booking_date = toDate(booking_date, \"yyyy-MM-dd HH:MM:SS\"),",
						"          timestamp = toTimestamp(timestamp, \"yyyy-MM-dd HH:MM:SS\")) ~> ModifyColumnsDataType",
						"ModifyColumnsDataType split(check_out_date>=check_in_date,",
						"     disjoint: false) ~> AcceptedRecords@(AcceptedRecords, BadRecords)",
						"LookupInSynapse alterRow(insertIf(isNull(SynapseForLookup@booking_id)),",
						"     upsertIf(not(isNull(selectColumns@booking_id)))) ~> AlterRow",
						"sourceBookingStage parse(parse_property_location = property_location ? (city as string,",
						"          country as string),",
						"     format: 'json',",
						"     documentForm: 'documentPerLine') ~> parseColumnInJson",
						"derivedColumns select(mapColumn(",
						"          booking_id,",
						"          property_id,",
						"          customer_id,",
						"          owner_id,",
						"          check_in_date,",
						"          check_out_date,",
						"          booking_date,",
						"          amount,",
						"          currency,",
						"          city,",
						"          country,",
						"          full_address,",
						"          stay_duration,",
						"          booking_year,",
						"          booking_month,",
						"          timestamp",
						"     ),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> selectColumns",
						"selectColumns, SynapseForLookup lookup(selectColumns@booking_id == SynapseForLookup@booking_id,",
						"     multiple: false,",
						"     pickup: 'first',",
						"     desc(SynapseForLookup@timestamp, true),",
						"     broadcast: 'auto')~> LookupInSynapse",
						"AlterRow select(mapColumn(",
						"          booking_id = selectColumns@booking_id,",
						"          property_id = selectColumns@property_id,",
						"          customer_id = selectColumns@customer_id,",
						"          owner_id = selectColumns@owner_id,",
						"          check_in_date = selectColumns@check_in_date,",
						"          check_out_date = selectColumns@check_out_date,",
						"          booking_date = selectColumns@booking_date,",
						"          amount = selectColumns@amount,",
						"          currency = selectColumns@currency,",
						"          city = selectColumns@city,",
						"          country = selectColumns@country,",
						"          full_address = selectColumns@full_address,",
						"          stay_duration = selectColumns@stay_duration,",
						"          booking_year = selectColumns@booking_year,",
						"          booking_month = selectColumns@booking_month,",
						"          timestamp = selectColumns@timestamp",
						"     ),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> FinalColumns",
						"FinalColumns sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     input(",
						"          booking_id as string,",
						"          property_id as string,",
						"          customer_id as integer,",
						"          owner_id as string,",
						"          check_in_date as date,",
						"          check_out_date as date,",
						"          booking_date as timestamp,",
						"          amount as double,",
						"          currency as string,",
						"          city as string,",
						"          country as string,",
						"          full_address as string,",
						"          stay_duration as long,",
						"          booking_year as integer,",
						"          booking_month as integer,",
						"          timestamp as timestamp",
						"     ),",
						"     deletable:false,",
						"     insertable:true,",
						"     updateable:true,",
						"     upsertable:false,",
						"     keys:['booking_id'],",
						"     format: 'table',",
						"     staged: true,",
						"     allowCopyCommand: true,",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     errorHandlingOption: 'stopOnFirstError') ~> SynapseFactWrite"
					]
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/BookingStageData')]",
				"[concat(variables('factoryId'), '/datasets/BookingFactSynapse')]",
				"[concat(variables('factoryId'), '/linkedServices/AzureDataLakeStorage1')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/LoadBookingFact')]",
			"type": "Microsoft.DataFactory/factories/pipelines",
			"apiVersion": "2018-06-01",
			"properties": {
				"description": "Load Booking data from MongoDB Collection into Synapse Booking fact table. ",
				"activities": [
					{
						"name": "LoadingMongoDBData",
						"description": "Loading Data from MongoDB Collection.",
						"type": "Copy",
						"dependsOn": [
							{
								"activity": "LookupInLastRunFile",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"source": {
								"type": "MongoDbAtlasSource",
								"batchSize": 100,
								"filter": {
									"value": "{\n    \"timestamp\":{\n        \"$gt\":{\n            \"$date\": \"@{activity('LookupInLastRunFile').output.firstRow.lastRunTime}\"\n        }\n    }\n}\n\n",
									"type": "Expression"
								}
							},
							"sink": {
								"type": "ParquetSink",
								"storeSettings": {
									"type": "AzureBlobFSWriteSettings",
									"copyBehavior": "PreserveHierarchy"
								},
								"formatSettings": {
									"type": "ParquetWriteSettings"
								}
							},
							"enableStaging": false,
							"parallelCopies": 1,
							"dataIntegrationUnits": 4
						},
						"inputs": [
							{
								"referenceName": "BookingMongodb",
								"type": "DatasetReference",
								"parameters": {}
							}
						],
						"outputs": [
							{
								"referenceName": "BookingStageData",
								"type": "DatasetReference",
								"parameters": {}
							}
						]
					},
					{
						"name": "LookupInLastRunFile",
						"description": "Fetch the last run field from json.",
						"type": "Lookup",
						"dependsOn": [],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"source": {
								"type": "JsonSource",
								"storeSettings": {
									"type": "AzureBlobFSReadSettings",
									"recursive": true,
									"enablePartitionDiscovery": false
								},
								"formatSettings": {
									"type": "JsonReadSettings"
								}
							},
							"dataset": {
								"referenceName": "Last_Run_File",
								"type": "DatasetReference",
								"parameters": {}
							},
							"firstRowOnly": true
						}
					},
					{
						"name": "TranformBookingData",
						"description": "This will transform the booking data.",
						"type": "ExecuteDataFlow",
						"dependsOn": [
							{
								"activity": "LoadingMongoDBData",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"dataflow": {
								"referenceName": "TransformDataToSynapse",
								"type": "DataFlowReference",
								"parameters": {},
								"datasetParameters": {
									"sourceBookingStage": {},
									"SynapseForLookup": {},
									"SynapseFactWrite": {}
								}
							},
							"staging": {
								"linkedService": {
									"referenceName": "AzureDataLakeStorage1",
									"type": "LinkedServiceReference"
								},
								"folderPath": "airbnb-data/Synapse-data"
							},
							"compute": {
								"coreCount": 8,
								"computeType": "General"
							},
							"traceLevel": "Fine"
						}
					},
					{
						"name": "TriggerStoredProcedure",
						"type": "SqlServerStoredProcedure",
						"dependsOn": [
							{
								"activity": "TranformBookingData",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"storedProcedureName": "[[airbnb].[BookingAggregation]"
						},
						"linkedServiceName": {
							"referenceName": "AzureSynapseAnalytics1",
							"type": "LinkedServiceReference"
						}
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"annotations": []
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/BookingMongodb')]",
				"[concat(variables('factoryId'), '/datasets/BookingStageData')]",
				"[concat(variables('factoryId'), '/datasets/Last_Run_File')]",
				"[concat(variables('factoryId'), '/dataflows/TransformDataToSynapse')]",
				"[concat(variables('factoryId'), '/linkedServices/AzureDataLakeStorage1')]",
				"[concat(variables('factoryId'), '/linkedServices/AzureSynapseAnalytics1')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/AirBnBCDCPipeline')]",
			"type": "Microsoft.DataFactory/factories/pipelines",
